# HealthPowr Environment Variables
# Copy this file to .env and fill in the values.

# ──── CLIENT-SIDE (embedded in browser bundle) ────
# These are PUBLIC keys — safe to be in the client bundle.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_SITE_URL=http://localhost:5173

# ──── SERVER-SIDE SECRETS ────
# These must NEVER have a VITE_ prefix!
# Set these as Supabase Function Secrets:
#   supabase secrets set SUPABASE_SERVICE_ROLE_KEY=<value>
#   supabase secrets set ADMIN_PASSKEY=<your-strong-passkey>
#   supabase secrets set ALLOWED_ORIGIN=https://your-production-domain.com
#
# DO NOT put these values in `.env` — they MUST ONLY live in Supabase Function Secrets.
